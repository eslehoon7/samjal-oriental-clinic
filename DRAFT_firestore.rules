rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // ID Validation Helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Notices Collection Rules
    match /notices/{noticeId} {
      allow read, write: if true;
    }

    // 3. galleryPhotos Collection Rules
    match /galleryPhotos/{photoId} {
      allow read, write: if true;
    }

    // 4. activities Collection Rules
    match /activities/{activityId} {
      allow read, write: if true;
    }

    // 5. diagnoses Collection Rules
    match /diagnoses/{diagnoseId} {
      allow read, write: if true;
    }
  }
}
